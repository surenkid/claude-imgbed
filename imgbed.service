[Unit]
Description=Image Hosting Service
Documentation=https://github.com/yourusername/imgbed
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/imgbed
ExecStart=/opt/imgbed/imgbed
Restart=on-failure
RestartSec=5s

# Environment variables
Environment="AUTH_TOKEN=change-me-in-production"

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/imgbed/uploads

# Resource limits
LimitNOFILE=65535
LimitNPROC=512

[Install]
WantedBy=multi-user.target
